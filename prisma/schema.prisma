// Prisma schema for Vastukruti Architects
// Existing generator and datasource definitions

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // The connection URL will be set via environment variable DATABASE_URL
}

// Placeholder Project model
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String?
  techStack   String[] // array of tech tags
  image       String   // path to image in public/projects
  demoUrl     String?  // live demo link
  repoUrl     String?  // GitHub repository link
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
