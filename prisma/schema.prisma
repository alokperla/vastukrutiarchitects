generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Enquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model ProjectEntry {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  category    String
  description String
  year        String
  location    String
  area        String
  coverImage  String
  gallery     String[] @default([])
  scope       String[] @default([])
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id        Int    @id @default(1)
  whatsapp  String @default("")
  email     String @default("")
  instagram String @default("")
  aboutText String @default("")
}
